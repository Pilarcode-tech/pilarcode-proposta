---
import "../styles/global.css";

import PasswordGate from "../components/sucalog/PasswordGate";
import Cover from "../components/sucalog/Cover";
import Contexto from "../components/sucalog/Contexto";
import Proposta from "../components/sucalog/Proposta";
import Integracoes from "../components/sucalog/Integracoes";
import Fases from "../components/sucalog/Fases";
import Entregaveis from "../components/sucalog/Entregaveis";
import Investimento from "../components/sucalog/Investimento";
import ProximosPassos from "../components/sucalog/ProximosPassos";
import Garantia from "../components/Garantia";
import Confidencialidade from "../components/Confidencialidade";
import SobreNos from "../components/SobreNos";
import Assinatura from "../components/sucalog/Assinatura";
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Proposta Comercial — Grupo Sucalog | Pilarcode Tech</title>
		<meta name="description" content="Proposta Comercial - Sistema de RH, Folha e Auditoria Trabalhista - Grupo Sucalog" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-white">
		<PasswordGate client:load>
			<header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
				<div class="mx-auto xl:container w-full px-4 sm:px-6 lg:px-10">
					<nav class="flex items-center justify-between py-4 gap-4 lg:gap-8">
						<a href="/" class="flex items-center gap-2.5">
							<img src="/icon.png" alt="Pilarcode" class="h-8 lg:h-10 w-auto shrink-0" />
							<div class="flex flex-col leading-none">
								<span class="font-bold text-[20px] lg:text-[24px] text-gray-900 tracking-tight leading-none">
									pilarcode
								</span>
								<span class="font-semibold text-[7px] lg:text-[8px] text-blue-light tracking-wide uppercase leading-none mt-[6px]">
									tech
								</span>
							</div>
						</a>
						<span class="font-manrope text-[10px] font-bold text-gray-400 uppercase tracking-[2px]">
							Proposta · Grupo Sucalog
						</span>
					</nav>
				</div>
			</header>

			<main>
				<Cover client:load />
				<Contexto />
				<Proposta />
				<Integracoes />
				<Fases />
				<Entregaveis />
				<Investimento />
				<ProximosPassos />
				<Garantia />
				<Confidencialidade />
				<SobreNos />
				<Assinatura />
			</main>
		</PasswordGate>
	</body>
</html>
